{
  "$schema": "https://json.schemastore.org/tsconfig",
  "_comment": "Drop-in maximally-strict base config. Extend it: { \"extends\": \"./tsconfig.strict.json\", \"compilerOptions\": { \"outDir\": \"dist\" }, \"include\": [\"src\"] }. Every flag below is load-bearing; do not relax one without a written reason.",
  "compilerOptions": {
    // ---- Type-checking: maximum strictness ----
    "strict": true,
    // ^ enables: noImplicitAny, strictNullChecks, strictFunctionTypes,
    //   strictBindCallApply, strictPropertyInitialization, noImplicitThis,
    //   useUnknownInCatchVariables, alwaysStrict.
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "noImplicitOverride": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "noPropertyAccessFromIndexSignature": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "allowUnusedLabels": false,
    "allowUnreachableCode": false,

    // ---- Modules ----
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "verbatimModuleSyntax": true,
    "isolatedModules": true,
    "resolveJsonModule": true,
    "forceConsistentCasingInFileNames": true,
    "moduleDetection": "force",

    // ---- Emit / output ----
    "target": "es2023",
    "lib": ["es2023"],
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "noEmitOnError": true,

    // ---- Performance / interop ----
    "skipLibCheck": true,
    "esModuleInterop": true
  }
}
